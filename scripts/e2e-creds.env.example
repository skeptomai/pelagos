# Pelagos registry auth E2E — credential configuration template
#
# Copy to scripts/.env, fill in your values, then run:
#
#   PELAGOS_E2E_GHCR_TOKEN=$(gh auth token) \
#   CREDS_FILE=scripts/.env \
#   sudo -E scripts/test-registry-auth-e2e.sh
#
# The .env file is gitignored — never commit real tokens.
#
# Each profile is skipped if its required variables are not set, so you can
# enable only the registries you have credentials for.
#
# To run a subset of profiles:
#   PELAGOS_E2E_REGISTRIES="ghcr-private dockerhub-public" \
#   PELAGOS_E2E_GHCR_TOKEN=$(gh auth token) \
#   CREDS_FILE=scripts/.env \
#   sudo -E scripts/test-registry-auth-e2e.sh
#
# Supported profiles:
#   ghcr-private       GHCR, private repo — pull after logout must fail
#   ghcr-public        GHCR, public repo  — pull after logout must succeed
#   dockerhub-private  Docker Hub, private repo
#   dockerhub-public   Docker Hub, public repo
#   ecr                AWS ECR (always private; token auto-fetched via aws CLI)

# ---------------------------------------------------------------------------
# GHCR (GitHub Container Registry)
#
# Token: must be passed on the command line, not in this file.
#   PELAGOS_E2E_GHCR_TOKEN=$(gh auth token)
# The token needs "write:packages" scope:
#   gh auth refresh --scopes write:packages
#
# Prerequisites:
#   Private image: new GHCR packages are private by default.
#   Public image:  push once, then make the package public in:
#                  github.com → Packages → <package> → Package settings → Change visibility
# ---------------------------------------------------------------------------
PELAGOS_E2E_GHCR_USER="your-github-username"
# PELAGOS_E2E_GHCR_TOKEN — pass on command line, not here
PELAGOS_E2E_GHCR_PRIVATE_IMAGE="ghcr.io/your-github-username/pelagos-e2e-private:latest"
PELAGOS_E2E_GHCR_PUBLIC_IMAGE="ghcr.io/your-github-username/pelagos-e2e-public:latest"

# ---------------------------------------------------------------------------
# Docker Hub
#
# Token: hub.docker.com → Account Settings → Personal access tokens
#        → Generate new token → Access: Read, Write, Delete
#
# Prerequisites:
#   Private repo: hub.docker.com → Repositories → Create → Private
#   Public repo:  hub.docker.com → Repositories → Create → Public
# ---------------------------------------------------------------------------
PELAGOS_E2E_DOCKERHUB_USER="your-dockerhub-username"
PELAGOS_E2E_DOCKERHUB_TOKEN="dckr_pat_..."
PELAGOS_E2E_DOCKERHUB_PRIVATE_IMAGE="docker.io/your-dockerhub-username/pelagos-e2e-private:latest"
PELAGOS_E2E_DOCKERHUB_PUBLIC_IMAGE="docker.io/your-dockerhub-username/pelagos-e2e-public:latest"

# ---------------------------------------------------------------------------
# AWS ECR (always private; token fetched automatically via AWS CLI)
#
# Prerequisites:
#   - AWS CLI installed and configured (env vars, ~/.aws/credentials, or IAM role)
#   - Repository must exist before running:
#       aws ecr create-repository --repository-name pelagos-e2e --region <region>
# ---------------------------------------------------------------------------
PELAGOS_E2E_ECR_REGISTRY="123456789012.dkr.ecr.us-east-1.amazonaws.com"
PELAGOS_E2E_ECR_REGION="us-east-1"
PELAGOS_E2E_ECR_IMAGE="123456789012.dkr.ecr.us-east-1.amazonaws.com/pelagos-e2e:latest"
