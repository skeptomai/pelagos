ARG PROFILE=release

FROM alpine AS builder
RUN apk add --no-cache rust cargo musl-dev build-base
COPY . /src
WORKDIR /src
RUN cargo build --$PROFILE --target x86_64-unknown-linux-musl

FROM alpine
COPY --from=builder /src/target/x86_64-unknown-linux-musl/release/hello-server /usr/local/bin/hello-server
EXPOSE 8080
CMD ["/usr/local/bin/hello-server"]
